    {
      "name": "05 — Featured (NGS-108)",
      "item": [
        {
          "name": "Featured — réponse de base",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TODO 1 — Status 200",
                  "pm.test(\"Le statut est 200 OK\", function () {",
                  "    pm.response.to.have.status(200)",
                  "})",
                  "",
                  "const data = pm.response.json()",
                  "",
                  "// TODO 2 — Réponse contient 'count' et 'featured'",
                  "pm.test(\"La réponse contient les champs 'count' et 'featured'\", function () {",
                  "    pm.expect(data).to.have.property('count')",
                  "    pm.expect(data).to.have.property('featured')",
                  "})",
                  "",
                  "// TODO 3 — 'featured' est un tableau de max 5 éléments",
                  "pm.test(\"'featured' est un tableau de maximum 5 éléments\", function () {",
                  "    pm.expect(data.featured).to.be.an('array')",
                  "    pm.expect(data.featured.length).to.be.at.most(5)",
                  "})",
                  "",
                  "// TODO 4 — Les jeux sont triés par rating décroissant",
                  "pm.test(\"Les jeux sont triés par rating décroissant\", function () {",
                  "    const featuredGames = data.featured",
                  "    ",
                  "    featuredGames.forEach((game, index) => {",
                  "",
                  "        if (index < featuredGames.length - 1) {",
                  "            const currentRating = game.rating;",
                  "            const nextRating = featuredGames[index + 1].rating",
                  "",
                  "",
                  "            pm.expect(currentRating).to.be.at.least(nextRating, ",
                  "                `Erreur à l'index ${index}: ${currentRating} devrait être >= ${nextRating}`)",
                  "        }",
                  "    })",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/games/featured",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "games",
                "featured"
              ]
            }
          },
          "response": []
        },
